{
  "name": "@thundrex/web-components",
  "version": "1.0.0",
  "description": "thundrex — Neumorphic design system and web component library built with Lit, with Tailwind CSS preset",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./tailwind-preset": "./tailwind-preset.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "tsc && vite build --config vite.lib.config.ts",
    "preview": "vite preview"
  },
  "keywords": ["web-components", "lit", "neumorphism", "design-system", "tailwind", "soft-ui"],
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.2.0"
  }
}
